{
  "manifest_version": 3,
  "name": "ASKAI 아스카이 스크린샷",
  "short_name": "ASKAI",
  "version": "0.1.0",
  "description": "마우스 오른쪽 클릭으로 현재 탭을 캡처하고 ASKAI에 복사하거나 저장합니다.",
  "permissions": ["activeTab", "clipboardWrite", "contextMenus", "downloads", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ASKAI 스크린샷",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
